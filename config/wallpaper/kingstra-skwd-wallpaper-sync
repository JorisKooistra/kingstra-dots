#!/usr/bin/env bash
# =============================================================================
# kingstra-skwd-wallpaper-sync
# -----------------------------------------------------------------------------
# Opent de skwd-wall picker en forceert daarna de centrale Kingstra apply-flow:
# actuele wallpaper + huidig theme-scheme/mode/color_index.
# =============================================================================
set -euo pipefail

LEGACY_DAEMON_QML="${XDG_CONFIG_HOME:-$HOME/.config}/skwd-wall/daemon.qml"
SKWD_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/skwd-wall/config.json"
THEME_JSON="${XDG_CONFIG_HOME:-$HOME/.config}/quickshell/theme.json"
APPLY_SCRIPT="${HOME}/.local/bin/apply-shell-state"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/kingstra"
LOCK_FILE="/tmp/kingstra-skwd-wallpaper-sync.lock"
MAX_POLLS=320
POLL_SLEEP="0.35"

LOG_PREFIX="[kingstra-skwd-sync]"
_log()  { echo "$LOG_PREFIX $*"; }
_warn() { echo "$LOG_PREFIX WARN: $*" >&2; }

_query_wallpaper_from_daemon() {
    local daemon_cmd="$1"
    command -v "$daemon_cmd" >/dev/null 2>&1 || return 1

    local line path
    line="$("$daemon_cmd" query 2>/dev/null | grep -m1 'image:' || true)"
    [[ -n "$line" ]] || return 1

    path="${line#*image: }"
    path="${path%% (}"
    [[ -n "$path" && -f "$path" ]] || return 1

    printf '%s\n' "$path"
    return 0
}

_current_wallpaper() {
    local path=""

    path="$(_query_wallpaper_from_daemon awww || true)"
    if [[ -n "$path" && -f "$path" ]]; then
        printf '%s\n' "$path"
        return 0
    fi

    path="$(_query_wallpaper_from_daemon swww || true)"
    if [[ -n "$path" && -f "$path" ]]; then
        printf '%s\n' "$path"
        return 0
    fi

    local candidate
    for candidate in \
        "${XDG_CACHE_HOME:-$HOME/.cache}/skwd-wall/current_wallpaper" \
        "${XDG_CACHE_HOME:-$HOME/.cache}/skwd-wall/current-wallpaper" \
        "${XDG_CACHE_HOME:-$HOME/.cache}/skwd-wall/last_wallpaper" \
        "${XDG_CACHE_HOME:-$HOME/.cache}/skwd-wall/last-wallpaper" \
        "${XDG_CONFIG_HOME:-$HOME/.config}/skwd-wall/state.json"; do
        [[ -f "$candidate" ]] || continue
        if [[ "$candidate" == *.json ]] && command -v jq >/dev/null 2>&1; then
            path="$(jq -r '.wallpaper // .currentWallpaper // .lastWallpaper // ""' "$candidate" 2>/dev/null || echo "")"
        else
            path="$(cat "$candidate" 2>/dev/null || true)"
        fi
        if [[ -n "$path" && -f "$path" ]]; then
            printf '%s\n' "$path"
            return 0
        fi
    done

    path="$(cat "$CACHE_DIR/last-wallpaper" 2>/dev/null || true)"
    if [[ -n "$path" && -f "$path" ]]; then
        printf '%s\n' "$path"
        return 0
    fi

    printf '%s\n' ""
}

_sync_skwd_config() {
    [[ -f "$SKWD_CONFIG" ]] || return 0
    if ! command -v jq >/dev/null 2>&1; then
        _warn "jq ontbreekt — skwd config sync overgeslagen"
        return 0
    fi

    local scheme mode
    scheme="$(jq -r '.scheme_type // "scheme-tonal-spot"' "$THEME_JSON" 2>/dev/null || echo "scheme-tonal-spot")"
    mode="$(jq -r '.mode // "dark"' "$THEME_JSON" 2>/dev/null || echo "dark")"

    local tmp_file
    tmp_file="$(mktemp)"
    if jq --arg scheme "$scheme" --arg mode "$mode" \
        '.features.matugen = false
         | .features.wallhaven = true
         | .matugen.schemeType = $scheme
         | .matugen.mode = $mode' \
        "$SKWD_CONFIG" > "$tmp_file" 2>/dev/null; then
        mv "$tmp_file" "$SKWD_CONFIG"
    else
        rm -f "$tmp_file"
        _warn "Kon skwd-wall config niet patchen"
    fi
}

_open_picker() {
    local opened=false

    if command -v skwd >/dev/null 2>&1; then
        systemctl --user start skwd-daemon.service >/dev/null 2>&1 || true
        if skwd wall toggle >/dev/null 2>&1; then
            opened=true
        else
            _warn "skwd wall toggle faalde"
        fi
    elif [[ -f "$LEGACY_DAEMON_QML" ]]; then
        if quickshell ipc -p "$LEGACY_DAEMON_QML" call wallpaper toggle >/dev/null 2>&1; then
            opened=true
        else
            _warn "legacy skwd-wall ipc call faalde"
        fi
    else
        _warn "skwd commando en legacy daemon ontbreken"
    fi

    if [[ "$opened" == "false" ]]; then
        notify-send "Wallpaper" "Kon skwd-wall picker niet openen" 2>/dev/null || true
        return 1
    fi

    return 0
}

_watch_and_apply() {
    local before="$1"

    exec 9>"$LOCK_FILE"
    if ! flock -n 9; then
        exit 0
    fi
    trap 'flock -u 9; rm -f "$LOCK_FILE"' EXIT

    local i current
    for ((i = 0; i < MAX_POLLS; i++)); do
        current="$(_current_wallpaper)"
        if [[ -n "$current" && "$current" != "$before" && -f "$current" ]]; then
            mkdir -p "$CACHE_DIR"
            printf '%s\n' "$current" > "$CACHE_DIR/last-wallpaper"

            if [[ -x "$APPLY_SCRIPT" ]]; then
                "$APPLY_SCRIPT" --wallpaper "$current" >/dev/null 2>&1 || true
                _log "Centrale apply uitgevoerd op: $(basename "$current")"
            else
                _warn "apply-shell-state niet gevonden"
            fi
            exit 0
        fi
        sleep "$POLL_SLEEP"
    done
}

if [[ "${1:-}" == "--watch" ]]; then
    _watch_and_apply "${2:-}"
    exit 0
fi

_sync_skwd_config
before_wallpaper="$(_current_wallpaper)"

_open_picker || exit 1
"$0" --watch "$before_wallpaper" >/dev/null 2>&1 &
disown
