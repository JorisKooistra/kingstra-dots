#!/usr/bin/env bash
# =============================================================================
# kingstra-skwd-wall-overlay-patch
# -----------------------------------------------------------------------------
# Builds a user-owned skwd-wall QML overlay and points skwd-daemon at it.
# This keeps Kingstra UI tweaks installer-managed without modifying /usr/share.
# =============================================================================
set -euo pipefail

SRC_DIR="${SKWD_WALL_SYSTEM_DIR:-/usr/share/skwd-wall}"
OVERLAY_DIR="${SKWD_WALL_OVERLAY_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/kingstra/skwd-wall-overlay}"
SERVICE_OVERRIDE_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user/skwd-daemon.service.d"
SERVICE_OVERRIDE="$SERVICE_OVERRIDE_DIR/10-kingstra-overlay.conf"

_log() { printf '[kingstra-skwd-overlay] %s\n' "$*"; }
_warn() { printf '[kingstra-skwd-overlay] WARN: %s\n' "$*" >&2; }

if [[ ! -f "$SRC_DIR/shell.qml" ]]; then
    _warn "skwd-wall system QML niet gevonden: $SRC_DIR"
    exit 0
fi

rm -rf "$OVERLAY_DIR"
mkdir -p "$(dirname "$OVERLAY_DIR")"
cp -a "$SRC_DIR" "$OVERLAY_DIR"

python3 - "$OVERLAY_DIR" <<'PY'
from pathlib import Path
import sys

root = Path(sys.argv[1])

def patch(path, replacements):
    file_path = root / path
    text = file_path.read_text()
    original = text
    for old, new in replacements:
        if old not in text:
            raise SystemExit(f"patch anchor not found in {file_path}: {old[:120]!r}")
        text = text.replace(old, new, 1)
    if text != original:
        file_path.write_text(text)

