#!/usr/bin/env bash
# =============================================================================
# apply-shell-state — Centrale apply pipeline: matugen + reloads
# =============================================================================
# Gebruik: apply-shell-state [--verbose] [--wallpaper <pad>]
#
# Resolve't wallpaper + theme-matugen-instellingen via `kingstra-matugen-run`
# en laat uitsluitend die runner Matugen uitvoeren.
# Daarna: optionele color-transform + app reloads.
# =============================================================================
set -euo pipefail

SESSION_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/kingstra/state/session.json"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/kingstra"
STATE_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/kingstra/state"
MODES_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/kingstra/modes"
MATUGEN_RUNNER=""
SKWD_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/skwd-wall/config.json"
TAGS_SCRIPT="${HOME}/.local/bin/kingstra-wallhaven-tags"
LOG_PREFIX="[apply-shell-state]"
VERBOSE=false
WALLPAPER_ARG=""

_log()  { echo "$LOG_PREFIX $*"; }
_warn() { echo "$LOG_PREFIX WARN: $*" >&2; }

_run_helper() {
    local helper="$1"
    shift

    if [[ -x "$helper" ]]; then
        "$helper" "$@"
    elif [[ -f "$helper" ]]; then
        case "$(head -n 1 "$helper" 2>/dev/null || true)" in
            *python*) python3 "$helper" "$@" ;;
            *) bash "$helper" "$@" ;;
        esac
    else
        return 127
    fi
}

SCRIPT_REALPATH="$(readlink -f "${BASH_SOURCE[0]}")"
REPO_ROOT="$(cd "$(dirname "$SCRIPT_REALPATH")/../../.." && pwd)"

resolve_matugen_runner() {
    if [[ -x "${HOME}/.local/bin/kingstra-matugen-run" ]]; then
        printf '%s\n' "${HOME}/.local/bin/kingstra-matugen-run"
        return 0
    fi

    local found=""
    found="$(command -v kingstra-matugen-run 2>/dev/null || true)"
    if [[ -n "$found" ]]; then
        printf '%s\n' "$found"
        return 0
    fi

    if [[ -x "$REPO_ROOT/config/shared/scripts/kingstra-matugen-run" ]]; then
        printf '%s\n' "$REPO_ROOT/config/shared/scripts/kingstra-matugen-run"
        return 0
    fi

    return 1
}

_sync_skwd_config() {
    local scheme="$1"
    local mode="$2"

    [[ -f "$SKWD_CONFIG" ]] || return 0
    if ! command -v jq >/dev/null 2>&1; then
        _warn "jq ontbreekt — skwd config sync overgeslagen"
        return 0
    fi

    local tmp_file
    tmp_file="$(mktemp)"
    if jq --arg scheme "$scheme" --arg mode "$mode" \
        '.features.matugen = false
         | .features.wallhaven = true
         | .matugen.schemeType = $scheme
         | .matugen.mode = $mode' \
        "$SKWD_CONFIG" > "$tmp_file" 2>/dev/null; then
        mv "$tmp_file" "$SKWD_CONFIG"
    else
        rm -f "$tmp_file"
        _warn "Kon skwd-wall config niet synchroniseren"
    fi
}

for arg in "$@"; do
    case "$arg" in
        --verbose|-v) VERBOSE=true ;;
    esac
done

# Parsen van extra opties (huidige wallpaper kan expliciet meegegeven worden)
while [[ $# -gt 0 ]]; do
    case "$1" in
        --verbose|-v)
            shift
            ;;
        --wallpaper|-w)
            shift
            if [[ $# -gt 0 ]]; then
                WALLPAPER_ARG="$1"
                shift
            else
                _warn "Optie --wallpaper verwacht een pad"
            fi
            ;;
        *)
            shift
            ;;
    esac
done

# ---------------------------------------------------------------------------
# Lockfile — voorkom race conditions bij gelijktijdige aanroepen
# ---------------------------------------------------------------------------
LOCK_FILE="/tmp/apply-shell-state.lock"
exec 9>"$LOCK_FILE"
if ! flock -w 20 9; then
    _warn "apply-shell-state lock timeout (20s) — afgebroken"
    exit 1
fi
trap 'flock -u 9; rm -f "$LOCK_FILE"' EXIT

# ---------------------------------------------------------------------------
# Stap 1 — Resolve inputs via centrale matugen-runner
# ---------------------------------------------------------------------------
THEME_NAME="botanical"
SCHEME="scheme-tonal-spot"
COLOR_IDX=0
MODE="dark"
WALLPAPER=""
MATUGEN_RUNNER="$(resolve_matugen_runner || true)"

if [[ ! -x "$MATUGEN_RUNNER" ]]; then
    _warn "kingstra-matugen-run niet gevonden — apply afgebroken"
    exit 1
else
    RUNNER_RESOLVE_ARGS=()
    if [[ -n "$WALLPAPER_ARG" ]]; then
        RUNNER_RESOLVE_ARGS+=(--wallpaper "$WALLPAPER_ARG")
    fi

    RESOLVED_JSON="$("$MATUGEN_RUNNER" "${RUNNER_RESOLVE_ARGS[@]}" --resolved-json 2>/dev/null || echo '{}')"

    THEME_NAME="$(echo "$RESOLVED_JSON" | jq -r '.theme // "botanical"' 2>/dev/null || echo "botanical")"
    SCHEME="$(echo "$RESOLVED_JSON" | jq -r '.scheme_type // "scheme-tonal-spot"' 2>/dev/null || echo "scheme-tonal-spot")"
    COLOR_IDX="$(echo "$RESOLVED_JSON" | jq -r '.color_index // 0' 2>/dev/null || echo "0")"
    MODE="$(echo "$RESOLVED_JSON" | jq -r '.mode // "dark"' 2>/dev/null || echo "dark")"
    WALLPAPER="$(echo "$RESOLVED_JSON" | jq -r '.wallpaper // ""' 2>/dev/null || echo "")"
fi

if [[ -z "$WALLPAPER" || ! -f "$WALLPAPER" ]]; then
    _warn "Geen geldige wallpaper gevonden — matugen overgeslagen, apps wel herladen"
fi

_sync_skwd_config "$SCHEME" "$MODE"

# Fallback: onbekende mode → office
SESSION_MODE=$(jq -r '.mode // "office"' "$SESSION_FILE" 2>/dev/null || echo "office")
case "$SESSION_MODE" in
    office|gaming|media) ;;
    *)
        _warn "Onbekende mode '${SESSION_MODE}' — fallback naar office"
        SESSION_MODE="office"
        ;;
esac

# Houd wallpaper state/cache gelijk met de centrale apply-run.
if [[ -n "$WALLPAPER" && -f "$WALLPAPER" ]]; then
    mkdir -p "$CACHE_DIR" "$STATE_DIR"
    printf '%s\n' "$WALLPAPER" > "$CACHE_DIR/last-wallpaper"
    jq -n \
        --arg name "$(basename "$WALLPAPER")" \
        --arg path "$WALLPAPER" \
        '{"name":$name,"path":$path}' \
        > "$STATE_DIR/wallpaper.json"

    _run_helper "$TAGS_SCRIPT" "$WALLPAPER" >/dev/null 2>&1 || true

    jq -n \
        --arg name "$THEME_NAME" \
        '{"name":$name}' \
        > "$STATE_DIR/theme.json"

    SESSION_UPDATE="${HOME}/.local/bin/kingstra-session-update"
    _run_helper "$SESSION_UPDATE" >/dev/null 2>&1 || true
fi

_log "Wallpaper: $(basename "${WALLPAPER:-leeg}")"
_log "Theme: ${THEME_NAME:-?} | Scheme: $SCHEME | Matugen mode: $MODE | Color index: $COLOR_IDX"
_log "Mode: $SESSION_MODE"

# ---------------------------------------------------------------------------
# Stap 3 — Matugen draaien (altijd via kingstra-matugen-run)
# ---------------------------------------------------------------------------
COLORS_JSON="{}"

if [[ -n "$WALLPAPER" && -f "$WALLPAPER" ]]; then
    if [[ -x "$MATUGEN_RUNNER" ]]; then
        # Eén aanroep: genereert templates én geeft kleur-JSON terug
        COLORS_JSON=$("$MATUGEN_RUNNER" --wallpaper "$WALLPAPER" --json hex 2>/dev/null || echo "{}")
        if [[ "$COLORS_JSON" == "{}" ]]; then
            _warn "matugen runner mislukt"
        else
            _log "Matugen templates gegenereerd"
        fi
        if $VERBOSE; then
            "$MATUGEN_RUNNER" --wallpaper "$WALLPAPER" --show-colors 2>/dev/null || true
        fi
    fi

    # Sla laatste geldige palette op als fallback
    mkdir -p "$CACHE_DIR"
    echo "$COLORS_JSON" > "$CACHE_DIR/last-colors.json"
else
    # Fallback: gebruik het laatst gegenereerde palette
    FALLBACK_COLORS="$CACHE_DIR/last-colors.json"
    if [[ -f "$FALLBACK_COLORS" ]]; then
        COLORS_JSON=$(cat "$FALLBACK_COLORS")
        _warn "Geen wallpaper — gebruikt laatste geldige palette uit cache"
    fi
fi

# ---------------------------------------------------------------------------
# Stap 4 — Color transform (optioneel)
# ---------------------------------------------------------------------------
COLOR_TRANSFORM="${HOME}/.local/bin/kingstra-color-transform"
if [[ -x "$COLOR_TRANSFORM" ]]; then
    echo "$COLORS_JSON" | "$COLOR_TRANSFORM" || _warn "color-transform mislukt — originele kleuren behouden"
    _log "Color transform toegepast"
fi

# ---------------------------------------------------------------------------
# Stap 5 — Mode profiel laden en mode.json uitbreiden
# ---------------------------------------------------------------------------
MODE_TOML="$MODES_DIR/${SESSION_MODE}.toml"
MODE_JSON="$STATE_DIR/mode.json"

if [[ -f "$MODE_TOML" ]] && command -v "${HOME}/.local/bin/kingstra-mode-read" &>/dev/null; then
    MODE_DATA=$("${HOME}/.local/bin/kingstra-mode-read" --json "$MODE_TOML" 2>/dev/null || echo "{}")
    MODULES=$(echo "$MODE_DATA" | jq -r '.modules.list // []' 2>/dev/null || echo "[]")
    AUTOHIDE=$(echo "$MODE_DATA" | jq -r '.bar.autohide // false' 2>/dev/null || echo "false")

    jq -n \
        --arg name "$SESSION_MODE" \
        --argjson modules "$MODULES" \
        --argjson bar_autohide "$AUTOHIDE" \
        '{"name":$name,"modules":$modules,"bar_autohide":$bar_autohide}' \
        > "$MODE_JSON"
    _log "mode.json bijgewerkt: $SESSION_MODE (autohide=$AUTOHIDE)"
else
    # Fallback: schrijf minimale mode.json
    echo "{\"name\":\"$SESSION_MODE\",\"modules\":[],\"bar_autohide\":false}" > "$MODE_JSON"
fi

# ---------------------------------------------------------------------------
# Stap 6 — Apps herladen
# ---------------------------------------------------------------------------
if command -v hyprctl &>/dev/null; then
    hyprctl reload 2>/dev/null || true
    _log "Hyprland herladen"
fi

# Quickshell hoeft niet herstart te worden: MatugenColors.qml en ThemeConfig.qml
# pollen colors.json en theme.json elke seconde en passen kleuren/instellingen
# automatisch aan zonder herstart.

if pgrep -x swaync &>/dev/null; then
    if swaync-client -rs 2>/dev/null; then
        _log "SwayNC CSS herladen"
    else
        pkill -x swaync 2>/dev/null || true
        sleep 0.3
        swaync &
        disown
        _log "SwayNC hard herstart"
    fi
fi

if pgrep -x kitty &>/dev/null; then
    pkill -USR1 kitty 2>/dev/null || true
    _log "Kitty herladen"
fi

_log "Klaar"
