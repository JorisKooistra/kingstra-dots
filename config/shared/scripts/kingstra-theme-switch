#!/usr/bin/env bash
# =============================================================================
# kingstra-theme-switch — Switch between Kingstra themes
# =============================================================================
# Usage: kingstra-theme-switch <theme_name>
#        kingstra-theme-switch --current         (print current theme)
#        kingstra-theme-switch --list             (list available themes)
# =============================================================================
set -euo pipefail

THEMES_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/kingstra/themes"
ACTIVE_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/kingstra/active-theme"
THEME_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/hypr/conf.d/35-theme.conf"
THEME_JSON="${XDG_CONFIG_HOME:-$HOME/.config}/quickshell/theme.json"
MATUGEN_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/matugen/config.toml"
SKWD_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/skwd-wall/config.json"
STATE_FILE="${XDG_CACHE_HOME:-$HOME/.cache}/kingstra/last-wallpaper"

READER="${HOME}/.local/bin/kingstra-theme-read"

LOG_PREFIX="[kingstra-theme-switch]"
_log()  { echo "$LOG_PREFIX $*"; }
_warn() { echo "$LOG_PREFIX WARN: $*" >&2; }

SCRIPT_REALPATH="$(readlink -f "${BASH_SOURCE[0]}")"
REPO_ROOT="$(cd "$(dirname "$SCRIPT_REALPATH")/../../.." && pwd)"

_notify() {
    notify-send --icon=preferences-desktop-theme \
                --app-name="kingstra" \
                "$1" "${2:-}" \
                --urgency=low \
                --expire-time=3000 \
                2>/dev/null || true
}

set_ini_value() {
    local file="$1"
    local section="$2"
    local key="$3"
    local value="$4"

    mkdir -p "$(dirname "$file")"
    [[ -f "$file" ]] || printf '[%s]\n' "$section" > "$file"

    python3 - "$file" "$section" "$key" "$value" <<'PY'
import sys
from pathlib import Path

path = Path(sys.argv[1])
section = sys.argv[2]
key = sys.argv[3]
value = sys.argv[4]

lines = path.read_text(encoding="utf-8").splitlines()
output = []
in_section = False
section_found = False
inserted = False

for line in lines:
    stripped = line.strip()
    if stripped.startswith("[") and stripped.endswith("]"):
        if in_section and not inserted:
            output.append(f"{key}={value}")
            inserted = True
        in_section = stripped == f"[{section}]"
        section_found = section_found or in_section
        output.append(line)
        continue

    if in_section and stripped.startswith(f"{key}="):
        output.append(f"{key}={value}")
        inserted = True
    else:
        output.append(line)

if not section_found:
    if output and output[-1] != "":
        output.append("")
    output.append(f"[{section}]")
    output.append(f"{key}={value}")
elif in_section and not inserted:
    output.append(f"{key}={value}")

path.write_text("\n".join(output) + "\n", encoding="utf-8")
PY
}

is_true() {
    local value="${1:-false}"
    case "${value,,}" in
        1|true|yes|on) return 0 ;;
        *) return 1 ;;
    esac
}

bool_json() {
    if is_true "${1:-false}"; then
        echo "true"
    else
        echo "false"
    fi
}

sync_skwd_config() {
    local scheme_type="$1"
    local mode="$2"

    [[ -f "$SKWD_CONFIG" ]] || return 0
    if ! command -v jq &>/dev/null; then
        _warn "jq niet gevonden — skwd-wall config niet gesynchroniseerd"
        return 0
    fi

    local tmp_file
    tmp_file="$(mktemp)"

    if jq \
        --arg scheme "$scheme_type" \
        --arg mode "$mode" \
        '
        .features.matugen = false
        | .features.wallhaven = true
        | .matugen.schemeType = $scheme
        | .matugen.mode = $mode
        ' "$SKWD_CONFIG" > "$tmp_file" 2>/dev/null; then
        mv "$tmp_file" "$SKWD_CONFIG"
        _log "skwd-wall config gesynchroniseerd (scheme: $scheme_type, mode: $mode, matugen=false)"
    else
        rm -f "$tmp_file"
        _warn "Kon skwd-wall config niet synchroniseren: $SKWD_CONFIG"
    fi
}

pick_enum() {
    local value="$1"
    local default_value="$2"
    local field="$3"
    shift 3
    local allowed
    for allowed in "$@"; do
        if [[ "$value" == "$allowed" ]]; then
            echo "$value"
            return 0
        fi
    done
    _warn "Ongeldige waarde voor $field ('$value'), fallback naar '$default_value'"
    echo "$default_value"
}

sanitize_int() {
    local value="$1"
    local default_value="$2"
    local min_value="$3"
    local max_value="$4"
    local field="$5"

    if [[ ! "$value" =~ ^-?[0-9]+$ ]]; then
        _warn "Ongeldige integer voor $field ('$value'), fallback naar '$default_value'"
        echo "$default_value"
        return 0
    fi

    if (( value < min_value )); then
        echo "$min_value"
    elif (( value > max_value )); then
        echo "$max_value"
    else
        echo "$value"
    fi
}

sanitize_float() {
    local value="$1"
    local default_value="$2"
    local min_value="$3"
    local max_value="$4"
    local field="$5"

    if [[ ! "$value" =~ ^-?[0-9]+([.][0-9]+)?$ ]]; then
        _warn "Ongeldige float voor $field ('$value'), fallback naar '$default_value'"
        echo "$default_value"
        return 0
    fi

    awk -v v="$value" -v min="$min_value" -v max="$max_value" 'BEGIN {
        if (v < min) v = min;
        if (v > max) v = max;
        print v;
    }'
}

resolve_asset_path() {
    local raw="${1:-}"
    local field="$2"

    if [[ -z "$raw" ]]; then
        echo ""
        return 0
    fi

    local expanded="$raw"
    if [[ "$expanded" == "~/"* ]]; then
        expanded="$HOME/${expanded#~/}"
    fi

    if [[ "$expanded" == /* ]]; then
        if [[ -f "$expanded" ]]; then
            echo "$expanded"
        else
            _warn "Asset niet gevonden voor $field: $expanded"
            echo ""
        fi
        return 0
    fi

    local candidate
    for candidate in "$REPO_ROOT/$expanded" "${XDG_CONFIG_HOME:-$HOME/.config}/$expanded" "$HOME/$expanded"; do
        if [[ -f "$candidate" ]]; then
            echo "$candidate"
            return 0
        fi
    done

    _warn "Asset niet gevonden voor $field: $raw"
    echo ""
}

asset_exists() {
    local raw="${1:-}"
    if [[ -z "$raw" ]]; then
        return 1
    fi

    local expanded="$raw"
    if [[ "$expanded" == "~/"* ]]; then
        expanded="$HOME/${expanded#~/}"
    fi

    if [[ "$expanded" == /* ]]; then
        [[ -f "$expanded" ]]
        return $?
    fi

    local candidate
    for candidate in "$REPO_ROOT/$expanded" "${XDG_CONFIG_HOME:-$HOME/.config}/$expanded" "$HOME/$expanded"; do
        if [[ -f "$candidate" ]]; then
            return 0
        fi
    done
    return 1
}

# ---------------------------------------------------------------------------
# Arguments
# ---------------------------------------------------------------------------
if [[ "${1:-}" == "--current" ]]; then
    cat "$ACTIVE_FILE" 2>/dev/null || echo "dusk"
    exit 0
fi

if [[ "${1:-}" == "--list" ]]; then
    "$READER" --list "$THEMES_DIR"
    exit 0
fi

THEME_NAME="${1:?Gebruik: kingstra-theme-switch <theme_naam>}"
THEME_FILE="$THEMES_DIR/${THEME_NAME}.toml"

if [[ ! -f "$THEME_FILE" ]]; then
    _warn "Thema niet gevonden: $THEME_FILE"
    exit 1
fi

_log "Overschakelen naar thema: $THEME_NAME"

# ---------------------------------------------------------------------------
# Read theme values via Python helper
# ---------------------------------------------------------------------------
eval "$("$READER" "$THEME_FILE")"

# Variables are now available as: META_NAME, MATUGEN_SCHEME_TYPE, APPEARANCE_BORDER_RADIUS, etc.

BAR_SHAPE_JSON=$(pick_enum "${BAR_SHAPE:-rounded}" "rounded" "bar.shape" \
    rounded organic-grown capsule block segmented-capsule beveled)
BAR_POSITION_JSON=$(pick_enum "${QUICKSHELL_BAR_POSITION:-top}" "top" "quickshell.bar_position" \
    top bottom left right)
BAR_WIDTH_MODE_JSON=$(pick_enum "${BAR_WIDTH_MODE:-full}" "full" "bar.width_mode" \
    full floating)
BAR_FLOATING_JSON=$(bool_json "${BAR_FLOATING:-false}")
BAR_ATTACH_TO_SCREEN_EDGE_JSON=$(bool_json "${BAR_ATTACH_TO_SCREEN_EDGE:-true}")
BAR_TOP_EDGE_STYLE_JSON=$(pick_enum "${BAR_TOP_EDGE_STYLE:-soft}" "soft" "bar.top_edge_style" \
    flush soft hard beveled)
BAR_BOTTOM_EDGE_STYLE_JSON=$(pick_enum "${BAR_BOTTOM_EDGE_STYLE:-soft}" "soft" "bar.bottom_edge_style" \
    flush soft hard beveled ornate-rounded)
CLOCK_STYLE_JSON=$(pick_enum "${BAR_CLOCK_STYLE:-digital}" "digital" "bar.clock_style" \
    digital analog hybrid)

WIDGET_SHAPE_JSON="${WIDGETS_SHAPE:-rounded}"
WIDGET_SURFACE_JSON="${WIDGETS_SURFACE:-standard}"

ORNAMENT_ENABLED_JSON=$(bool_json "${ORNAMENTS_ENABLED:-false}")
ORNAMENT_TOP_LEFT_JSON=$(resolve_asset_path "${ORNAMENTS_TOP_LEFT:-}" "ornaments.top_left")
ORNAMENT_TOP_RIGHT_JSON=$(resolve_asset_path "${ORNAMENTS_TOP_RIGHT:-}" "ornaments.top_right")
ORNAMENT_OPACITY_JSON=$(sanitize_float "${ORNAMENTS_OPACITY:-0.0}" "0.0" "0.0" "1.0" "ornaments.opacity")

PARTICLE_TYPE_JSON=$(pick_enum "${EFFECTS_PARTICLES:-none}" "none" "effects.particles" \
    none fireflies space-specks)
PARTICLE_COUNT_JSON=$(sanitize_int "${EFFECTS_PARTICLE_COUNT:-0}" "0" "0" "50" "effects.particle_count")
PARTICLE_SPEED_JSON=$(sanitize_float "${EFFECTS_PARTICLE_SPEED:-0.0}" "0.0" "0.0" "2.0" "effects.particle_speed")

TERMINAL_OVERLAY_ASSET_JSON=$(resolve_asset_path "${TERMINAL_VISUAL_OVERLAY_ASSET:-}" "terminal_visual.overlay_asset")
TERMINAL_OVERLAY_OPACITY_JSON=$(sanitize_float "${TERMINAL_VISUAL_OVERLAY_OPACITY:-0.0}" "0.0" "0.0" "1.0" "terminal_visual.overlay_opacity")
TEXTURE_OVERLAY_ASSET_JSON=""
if [[ -n "${MATERIAL_TEXTURE_ASSET:-}" ]]; then
    TEXTURE_OVERLAY_ASSET_JSON=$(resolve_asset_path "${MATERIAL_TEXTURE_ASSET}" "material.texture_asset")
else
    DEFAULT_TEXTURE_REL="assets/themes/${THEME_NAME}/texture-overlay.png"
    if asset_exists "$DEFAULT_TEXTURE_REL"; then
        TEXTURE_OVERLAY_ASSET_JSON=$(resolve_asset_path "$DEFAULT_TEXTURE_REL" "material.texture_asset")
    fi
fi

# ---------------------------------------------------------------------------
# Theme style profiles — one coherent visual language per theme
# ---------------------------------------------------------------------------
STYLE_FAMILY="botanical"
STYLE_DENSITY="comfortable"
STYLE_SURFACE_MODE="soft-glass"
STYLE_MOTION="gentle"
STYLE_ORNAMENT="organic"
STYLE_PANEL_SHADOW=0.22
STYLE_OUTLINE_STRENGTH=0.18
STYLE_GLASS_STRENGTH=0.10
STYLE_WIDGET_RADIUS=${APPEARANCE_BORDER_RADIUS:-12}
STYLE_PANEL_PADDING=14

case "$THEME_NAME" in
    animated)
        STYLE_FAMILY="animated"
        STYLE_DENSITY="comfortable"
        STYLE_SURFACE_MODE="vivid-glass"
        STYLE_MOTION="playful"
        STYLE_ORNAMENT="kinetic"
        STYLE_PANEL_SHADOW=0.28
        STYLE_OUTLINE_STRENGTH=0.22
        STYLE_GLASS_STRENGTH=0.16
        STYLE_WIDGET_RADIUS=18
        STYLE_PANEL_PADDING=15
        ;;
    botanical)
        STYLE_FAMILY="botanical"
        STYLE_DENSITY="comfortable"
        STYLE_SURFACE_MODE="soft-glass"
        STYLE_MOTION="gentle"
        STYLE_ORNAMENT="organic"
        STYLE_PANEL_SHADOW=0.22
        STYLE_OUTLINE_STRENGTH=0.18
        STYLE_GLASS_STRENGTH=0.10
        STYLE_WIDGET_RADIUS=20
        STYLE_PANEL_PADDING=15
        ;;
    cyber)
        STYLE_FAMILY="cyber"
        STYLE_DENSITY="compact"
        STYLE_SURFACE_MODE="hard-surface"
        STYLE_MOTION="snappy"
        STYLE_ORNAMENT="grid"
        STYLE_PANEL_SHADOW=0.34
        STYLE_OUTLINE_STRENGTH=0.40
        STYLE_GLASS_STRENGTH=0.03
        STYLE_WIDGET_RADIUS=6
        STYLE_PANEL_PADDING=10
        ;;
    ocean)
        STYLE_FAMILY="ocean"
        STYLE_DENSITY="airy"
        STYLE_SURFACE_MODE="mist"
        STYLE_MOTION="smooth"
        STYLE_ORNAMENT="flow"
        STYLE_PANEL_SHADOW=0.26
        STYLE_OUTLINE_STRENGTH=0.16
        STYLE_GLASS_STRENGTH=0.12
        STYLE_WIDGET_RADIUS=18
        STYLE_PANEL_PADDING=16
        ;;
    rocky)
        STYLE_FAMILY="rocky"
        STYLE_DENSITY="compact"
        STYLE_SURFACE_MODE="solid"
        STYLE_MOTION="firm"
        STYLE_ORNAMENT="minimal"
        STYLE_PANEL_SHADOW=0.12
        STYLE_OUTLINE_STRENGTH=0.34
        STYLE_GLASS_STRENGTH=0.02
        STYLE_WIDGET_RADIUS=4
        STYLE_PANEL_PADDING=9
        ;;
    space)
        STYLE_FAMILY="space"
        STYLE_DENSITY="airy"
        STYLE_SURFACE_MODE="cinematic-glass"
        STYLE_MOTION="float"
        STYLE_ORNAMENT="cosmic"
        STYLE_PANEL_SHADOW=0.32
        STYLE_OUTLINE_STRENGTH=0.18
        STYLE_GLASS_STRENGTH=0.14
        STYLE_WIDGET_RADIUS=16
        STYLE_PANEL_PADDING=16
        ;;
esac

# ---------------------------------------------------------------------------
# Step 1 — Update matugen config.toml (scheme_type + color_index)
# ---------------------------------------------------------------------------
if [[ -f "$MATUGEN_CONF" ]]; then
    sed -i "s|^scheme_type\s*=.*|scheme_type = \"${MATUGEN_SCHEME_TYPE:-scheme-tonal-spot}\"|" "$MATUGEN_CONF"
    sed -i "s|^color_index\s*=.*|color_index = ${MATUGEN_COLOR_INDEX:-0}|" "$MATUGEN_CONF"
    sed -i "s|^mode\s*=.*|mode = \"${MATUGEN_MODE:-dark}\"|" "$MATUGEN_CONF"
    _log "Matugen config bijgewerkt (scheme: ${MATUGEN_SCHEME_TYPE:-scheme-tonal-spot}, mode: ${MATUGEN_MODE:-dark})"
fi
sync_skwd_config "${MATUGEN_SCHEME_TYPE:-scheme-tonal-spot}" "${MATUGEN_MODE:-dark}"

# ---------------------------------------------------------------------------
# Step 2 — Generate 35-theme.conf (Hyprland overrides)
# ---------------------------------------------------------------------------
mkdir -p "$(dirname "$THEME_CONF")"
cat > "$THEME_CONF" <<EOF
# =============================================================================
# 35-theme.conf — Automatisch gegenereerd door kingstra-theme-switch
# Thema: ${META_NAME:-$THEME_NAME}
# =============================================================================

general {
    gaps_in = ${APPEARANCE_GAPS_IN:-5}
    gaps_out = ${APPEARANCE_GAPS_OUT:-10}
    border_size = ${APPEARANCE_BORDER_WIDTH:-2}
}

decoration {
    rounding = ${APPEARANCE_BORDER_RADIUS:-12}
    blur {
        size = ${APPEARANCE_BLUR_SIZE:-8}
        passes = ${APPEARANCE_BLUR_PASSES:-3}
    }
}
EOF
_log "35-theme.conf gegenereerd"

# ---------------------------------------------------------------------------
# Step 3 — Generate theme.json (QuickShell via FileView)
# ---------------------------------------------------------------------------
mkdir -p "$(dirname "$THEME_JSON")"
cat > "$THEME_JSON" <<EOF
{
    "theme": "${THEME_NAME}",
    "name": "${META_NAME:-$THEME_NAME}",
    "icon": "${META_ICON:-󰏘}",
    "border_radius": ${APPEARANCE_BORDER_RADIUS:-12},
    "border_width": ${APPEARANCE_BORDER_WIDTH:-2},
    "gaps_in": ${APPEARANCE_GAPS_IN:-5},
    "gaps_out": ${APPEARANCE_GAPS_OUT:-10},
    "bar_opacity": ${APPEARANCE_BAR_OPACITY:-0.85},
    "popup_opacity": ${APPEARANCE_POPUP_OPACITY:-0.92},
    "blur_size": ${APPEARANCE_BLUR_SIZE:-8},
    "blur_passes": ${APPEARANCE_BLUR_PASSES:-3},
    "animation_speed": ${APPEARANCE_ANIMATION_SPEED:-1.0},
    "ui_font": "${FONTS_UI_FONT:-Inter}",
    "ui_font_size": ${FONTS_UI_FONT_SIZE:-13},
    "mono_font": "${FONTS_MONO_FONT:-JetBrainsMono Nerd Font}",
    "mono_font_size": ${FONTS_MONO_FONT_SIZE:-12},
    "icon_theme": "${ICONS_ICON_THEME:-Papirus-Dark}",
    "bar_height": ${QUICKSHELL_BAR_HEIGHT:-36},
    "bar_position": "${BAR_POSITION_JSON}",
    "bar_shape": "${BAR_SHAPE_JSON}",
    "bar_width_mode": "${BAR_WIDTH_MODE_JSON}",
    "bar_floating": ${BAR_FLOATING_JSON},
    "bar_attach_to_screen_edge": ${BAR_ATTACH_TO_SCREEN_EDGE_JSON},
    "bar_top_edge_style": "${BAR_TOP_EDGE_STYLE_JSON}",
    "bar_bottom_edge_style": "${BAR_BOTTOM_EDGE_STYLE_JSON}",
    "clock_style": "${CLOCK_STYLE_JSON}",
    "widget_shape": "${WIDGET_SHAPE_JSON}",
    "widget_surface": "${WIDGET_SURFACE_JSON}",
    "ornament_enabled": ${ORNAMENT_ENABLED_JSON},
    "ornament_top_left": "${ORNAMENT_TOP_LEFT_JSON}",
    "ornament_top_right": "${ORNAMENT_TOP_RIGHT_JSON}",
    "ornament_opacity": ${ORNAMENT_OPACITY_JSON},
    "particle_type": "${PARTICLE_TYPE_JSON}",
    "particle_count": ${PARTICLE_COUNT_JSON},
    "particle_speed": ${PARTICLE_SPEED_JSON},
    "texture_overlay_asset": "${TEXTURE_OVERLAY_ASSET_JSON}",
    "terminal_overlay_asset": "${TERMINAL_OVERLAY_ASSET_JSON}",
    "terminal_overlay_opacity": ${TERMINAL_OVERLAY_OPACITY_JSON},
    "scheme_type": "${MATUGEN_SCHEME_TYPE:-scheme-tonal-spot}",
    "color_index": ${MATUGEN_COLOR_INDEX:-0},
    "contrast": ${MATUGEN_CONTRAST:-0.0},
    "mode": "${MATUGEN_MODE:-dark}",
    "display_font": "${FONTS_DISPLAY_FONT:-${FONTS_UI_FONT:-Inter}}",
    "font_weight": "${FONTS_FONT_WEIGHT:-regular}",
    "letter_spacing": ${FONTS_LETTER_SPACING:-0.0},
    "color_transform": {
        "hue_shift": ${COLOR_TRANSFORM_HUE_SHIFT:-0},
        "saturation_adjust": ${COLOR_TRANSFORM_SATURATION_ADJUST:-0.0},
        "lightness_adjust": ${COLOR_TRANSFORM_LIGHTNESS_ADJUST:-0.0},
        "thematic_mix": ${COLOR_TRANSFORM_THEMATIC_MIX:-0.0}
    },
    "material": {
        "texture": "${MATERIAL_TEXTURE:-none}",
        "texture_asset": "${TEXTURE_OVERLAY_ASSET_JSON}",
        "overlay_opacity": ${MATERIAL_OVERLAY_OPACITY:-0.0},
        "glow_intensity": ${MATERIAL_GLOW_INTENSITY:-0.0}
    },
    "style_profile": {
        "family": "${STYLE_FAMILY}",
        "density": "${STYLE_DENSITY}",
        "surface_mode": "${STYLE_SURFACE_MODE}",
        "motion": "${STYLE_MOTION}",
        "ornament": "${STYLE_ORNAMENT}",
        "panel_shadow": ${STYLE_PANEL_SHADOW},
        "outline_strength": ${STYLE_OUTLINE_STRENGTH},
        "glass_strength": ${STYLE_GLASS_STRENGTH},
        "widget_radius": ${STYLE_WIDGET_RADIUS},
        "panel_padding": ${STYLE_PANEL_PADDING}
    },
    "terminal": {
        "bg_opacity": ${TERMINAL_BG_OPACITY:-0.90},
        "blur": ${TERMINAL_BLUR:-false},
        "padding": ${TERMINAL_PADDING:-10},
        "cursor_style": "${TERMINAL_CURSOR_STYLE:-block}"
    }
}
EOF
_log "theme.json gegenereerd"

WALKER_THEME_CSS="${XDG_CONFIG_HOME:-$HOME/.config}/walker/theme.css"
SWAYNC_THEME_CSS="${XDG_CONFIG_HOME:-$HOME/.config}/swaync/theme.css"
mkdir -p "$(dirname "$WALKER_THEME_CSS")" "$(dirname "$SWAYNC_THEME_CSS")"

cat > "$WALKER_THEME_CSS" <<EOF
#window {
  background: color-mix(in srgb, var(--mantle) $(python3 -c "print(round(min(98, max(72, (${APPEARANCE_POPUP_OPACITY:-0.92} + ${STYLE_GLASS_STRENGTH} * 0.35) * 100))))")%, transparent);
  border: ${APPEARANCE_BORDER_WIDTH:-1}px solid color-mix(in srgb, var(--outline) $(python3 -c "print(round(${STYLE_OUTLINE_STRENGTH} * 100))")%, transparent);
  border-radius: ${STYLE_WIDGET_RADIUS}px;
  box-shadow: 0 14px 40px color-mix(in srgb, var(--crust) $(python3 -c "print(round(${STYLE_PANEL_SHADOW} * 100))")%, transparent);
  font-family: "${FONTS_UI_FONT:-Inter}", sans-serif;
}

#search {
  font-size: ${FONTS_UI_FONT_SIZE:-13}px;
  padding: ${STYLE_PANEL_PADDING}px $((STYLE_PANEL_PADDING + 4))px;
}

row {
  border-radius: $(( STYLE_WIDGET_RADIUS > 8 ? STYLE_WIDGET_RADIUS - 8 : 4 ))px;
  margin: $([[ "$STYLE_DENSITY" == "compact" ]] && echo "1" || ([[ "$STYLE_DENSITY" == "airy" ]] && echo "3" || echo "2"))px 2px;
  padding: $([[ "$STYLE_DENSITY" == "compact" ]] && echo "5" || ([[ "$STYLE_DENSITY" == "airy" ]] && echo "8" || echo "6"))px $((STYLE_PANEL_PADDING - 2))px;
}

row:selected,
row:hover {
  background: color-mix(in srgb, var(--primary) $(python3 -c "print(round((0.10 + ${STYLE_GLASS_STRENGTH} * 0.60) * 100))")%, var(--surface));
}

#name {
  font-family: "${FONTS_DISPLAY_FONT:-${FONTS_UI_FONT:-Inter}}", sans-serif;
  font-weight: 600;
}

#description,
#label,
#typeahead {
  font-family: "${FONTS_UI_FONT:-Inter}", sans-serif;
}

#calc-result {
  font-family: "${FONTS_MONO_FONT:-JetBrainsMono Nerd Font}", monospace;
}
EOF

cat > "$SWAYNC_THEME_CSS" <<EOF
* {
  font-family: "${FONTS_UI_FONT:-Inter}", "${FONTS_MONO_FONT:-JetBrainsMono Nerd Font}", sans-serif;
  font-size: ${FONTS_UI_FONT_SIZE:-13}px;
}

.control-center {
  background: alpha(@mantle, $(python3 -c "print(min(0.99, max(0.76, ${APPEARANCE_POPUP_OPACITY:-0.92} + ${STYLE_GLASS_STRENGTH} * 0.20)))"));
  border: ${APPEARANCE_BORDER_WIDTH:-1}px solid alpha(@outline, ${STYLE_OUTLINE_STRENGTH});
  border-radius: $((STYLE_WIDGET_RADIUS + 4))px;
  box-shadow: 0 18px 52px alpha(@crust, ${STYLE_PANEL_SHADOW});
  padding: ${STYLE_PANEL_PADDING}px;
}

.widget-title > button,
.widget-dnd,
.notification,
.widget-mpris-player,
.notification-action {
  border-radius: ${STYLE_WIDGET_RADIUS}px;
}

.widget-title > button,
.widget-dnd,
.widget-mpris-player,
.notification {
  background: alpha(@surface0, $(python3 -c "print(min(0.98, max(0.74, ${APPEARANCE_POPUP_OPACITY:-0.92} + ${STYLE_GLASS_STRENGTH} * 0.15)))"));
}

.notification {
  border: ${APPEARANCE_BORDER_WIDTH:-1}px solid alpha(@outline-variant, ${STYLE_OUTLINE_STRENGTH});
}

.app-name,
.summary {
  font-family: "${FONTS_DISPLAY_FONT:-${FONTS_UI_FONT:-Inter}}", sans-serif;
}

.body,
.time {
  font-family: "${FONTS_UI_FONT:-Inter}", sans-serif;
}
EOF

_log "Walker/SwayNC theme overrides gegenereerd"

# ---------------------------------------------------------------------------
# Step 4 — Apply Hyprland changes live (no reload needed for keywords)
# ---------------------------------------------------------------------------
if command -v hyprctl &>/dev/null; then
    hyprctl keyword general:gaps_in "${APPEARANCE_GAPS_IN:-5}" 2>/dev/null || true
    hyprctl keyword general:gaps_out "${APPEARANCE_GAPS_OUT:-10}" 2>/dev/null || true
    hyprctl keyword general:border_size "${APPEARANCE_BORDER_WIDTH:-2}" 2>/dev/null || true
    hyprctl keyword decoration:rounding "${APPEARANCE_BORDER_RADIUS:-12}" 2>/dev/null || true
    hyprctl keyword decoration:blur:size "${APPEARANCE_BLUR_SIZE:-8}" 2>/dev/null || true
    hyprctl keyword decoration:blur:passes "${APPEARANCE_BLUR_PASSES:-3}" 2>/dev/null || true
    _log "Hyprland live bijgewerkt"
fi

# ---------------------------------------------------------------------------
# Step 5 — Update Kitty runtime overrides (no direct edits to tracked kitty.conf)
# ---------------------------------------------------------------------------
KITTY_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/kitty/kitty.conf"
KITTY_RUNTIME_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/kitty/kitty-runtime.conf"
if [[ -f "$KITTY_CONF" ]]; then
    mkdir -p "$(dirname "$KITTY_RUNTIME_CONF")"
    MONO="${FONTS_MONO_FONT:-JetBrainsMono Nerd Font}"
    MONO_SIZE="${FONTS_MONO_FONT_SIZE:-12}"
    OPACITY="${TERMINAL_BG_OPACITY:-0.90}"
    PADDING="${TERMINAL_PADDING:-10}"
    cat > "$KITTY_RUNTIME_CONF" <<EOF
# Auto-generated by kingstra-theme-switch
font_family ${MONO}
font_size ${MONO_SIZE}
background_opacity ${OPACITY}
window_padding_width ${PADDING}
EOF
    pkill -USR1 kitty 2>/dev/null || true
    _log "Kitty runtime overrides bijgewerkt"
fi

# ---------------------------------------------------------------------------
# Step 5b — Update GTK, Qt and desktop interface font/icon theme
# ---------------------------------------------------------------------------
GTK3_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/gtk-3.0/settings.ini"
GTK4_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/gtk-4.0/settings.ini"
GTK2_CONF="$HOME/.gtkrc-2.0"
QT6CT_CONF="${XDG_CONFIG_HOME:-$HOME/.config}/qt6ct/qt6ct.conf"
UI_FONT_NAME="${FONTS_UI_FONT:-Inter} ${FONTS_UI_FONT_SIZE:-13}"
ICON_THEME_NAME="${ICONS_ICON_THEME:-Papirus-Dark}"

for gtk_conf in "$GTK3_CONF" "$GTK4_CONF"; do
    mkdir -p "$(dirname "$gtk_conf")"
    [[ -f "$gtk_conf" ]] || printf '[Settings]\n' > "$gtk_conf"
    sed -i "/^\[Settings\]/,/^\[/ s|^gtk-font-name=.*|gtk-font-name=${UI_FONT_NAME}|" "$gtk_conf" 2>/dev/null || true
    sed -i "/^\[Settings\]/,/^\[/ s|^gtk-icon-theme-name=.*|gtk-icon-theme-name=${ICON_THEME_NAME}|" "$gtk_conf" 2>/dev/null || true
    grep -q '^gtk-font-name=' "$gtk_conf" || sed -i "/^\[Settings\]/a gtk-font-name=${UI_FONT_NAME}" "$gtk_conf"
    grep -q '^gtk-icon-theme-name=' "$gtk_conf" || sed -i "/^\[Settings\]/a gtk-icon-theme-name=${ICON_THEME_NAME}" "$gtk_conf"
done

if [[ -f "$GTK2_CONF" ]]; then
    sed -i "s|^gtk-font-name=.*|gtk-font-name=\"${UI_FONT_NAME}\"|" "$GTK2_CONF" 2>/dev/null || true
    sed -i "s|^gtk-icon-theme-name=.*|gtk-icon-theme-name=\"${ICON_THEME_NAME}\"|" "$GTK2_CONF" 2>/dev/null || true
else
    cat > "$GTK2_CONF" <<EOF
gtk-font-name="${UI_FONT_NAME}"
gtk-icon-theme-name="${ICON_THEME_NAME}"
EOF
fi

set_ini_value "$QT6CT_CONF" "Appearance" "icon_theme" "$ICON_THEME_NAME"

if command -v gsettings &>/dev/null; then
    gsettings set org.gnome.desktop.interface font-name "$UI_FONT_NAME" 2>/dev/null || true
    gsettings set org.gnome.desktop.interface icon-theme "$ICON_THEME_NAME" 2>/dev/null || true
fi

_log "GTK/Qt interface bijgewerkt"

# ---------------------------------------------------------------------------
# Step 6 — Kleuren hergenereren + apps herladen via apply-shell-state
# ---------------------------------------------------------------------------
APPLY="${HOME}/.local/bin/apply-shell-state"
if [[ -x "$APPLY" ]]; then
    CURRENT_WALLPAPER=""
    if command -v swww >/dev/null 2>&1; then
        _line="$(swww query 2>/dev/null | grep -m1 'image:' || true)"
        if [[ -n "$_line" ]]; then
            CURRENT_WALLPAPER="${_line#*image: }"
            CURRENT_WALLPAPER="${CURRENT_WALLPAPER%% (}"
        fi
    fi
    if [[ -z "$CURRENT_WALLPAPER" || ! -f "$CURRENT_WALLPAPER" ]] && [[ -f "$STATE_FILE" ]]; then
        CURRENT_WALLPAPER="$(cat "$STATE_FILE" 2>/dev/null || echo "")"
    fi
    if [[ -n "$CURRENT_WALLPAPER" && -f "$CURRENT_WALLPAPER" ]]; then
        "$APPLY" --wallpaper "$CURRENT_WALLPAPER" || _warn "apply-shell-state mislukt"
    else
        "$APPLY" || _warn "apply-shell-state mislukt"
    fi
    _log "Kleuren hergegenereerd en apps herladen"
else
    _warn "apply-shell-state niet gevonden — kleuren en apps niet herladen"
fi

# ---------------------------------------------------------------------------
# Step 7 — Save active theme
# ---------------------------------------------------------------------------
mkdir -p "$(dirname "$ACTIVE_FILE")"
echo "$THEME_NAME" > "$ACTIVE_FILE"
_log "Actief thema opgeslagen: $THEME_NAME"

# ---------------------------------------------------------------------------
# Step 8 — Update state/theme.json + session.json
# ---------------------------------------------------------------------------
STATE_WRITE="${HOME}/.local/bin/kingstra-state-write"
if [[ -x "$STATE_WRITE" ]]; then
    "$STATE_WRITE" theme.json name "$THEME_NAME"
    _log "state/theme.json bijgewerkt"
fi

SESSION_UPDATE="${HOME}/.local/bin/kingstra-session-update"
if [[ -x "$SESSION_UPDATE" ]]; then
    "$SESSION_UPDATE"
    _log "session.json bijgewerkt"
fi

_notify "Thema: ${META_NAME:-$THEME_NAME}" "Stijl succesvol toegepast"
