#!/usr/bin/env python3
# =============================================================================
# kingstra-color-transform — Pas matugen kleuren subtiel aan per theme
# =============================================================================
# Gebruik: echo "$MATUGEN_JSON" | kingstra-color-transform
#
# Leest matugen --json hex output van stdin.
# Leest color_transform waarden uit quickshell/theme.json.
# Past hue/saturation/lightness subtiel aan.
# Schrijft aangepaste kleuren naar ~/.config/quickshell/colors-transformed.json
# =============================================================================

import sys
import json
import os
import colorsys

THEME_JSON = os.path.expanduser(
    os.environ.get("XDG_CONFIG_HOME", os.path.expanduser("~/.config"))
    + "/quickshell/theme.json"
)
OUTPUT_FILE = os.path.expanduser(
    os.environ.get("XDG_CONFIG_HOME", os.path.expanduser("~/.config"))
    + "/quickshell/colors-transformed.json"
)


def hex_to_rgb(h):
    """Parse '#rrggbb' → (r, g, b) floats 0–1."""
    h = h.lstrip("#")
    if len(h) != 6:
        return None
    try:
        r = int(h[0:2], 16) / 255
        g = int(h[2:4], 16) / 255
        b = int(h[4:6], 16) / 255
        return r, g, b
    except ValueError:
        return None


def rgb_to_hex(r, g, b):
    """(r, g, b) floats 0–1 → '#rrggbb'."""
    return "#{:02x}{:02x}{:02x}".format(
        round(r * 255), round(g * 255), round(b * 255)
    )


def clamp(v, lo=0.0, hi=1.0):
    return max(lo, min(hi, v))


def transform_color(hex_color, hue_shift, sat_adj, light_adj):
    """Apply HSL transform to a hex color string."""
    rgb = hex_to_rgb(hex_color)
    if rgb is None:
        return hex_color

    h, l, s = colorsys.rgb_to_hls(*rgb)

    h = (h + hue_shift / 360.0) % 1.0
    s = clamp(s + sat_adj)
    l = clamp(l + light_adj)

    r, g, b = colorsys.hls_to_rgb(h, l, s)
    return rgb_to_hex(r, g, b)


def write_colors(data):
    """Write color data (transformed or original) to the output file."""
    os.makedirs(os.path.dirname(OUTPUT_FILE), exist_ok=True)
    with open(OUTPUT_FILE, "w") as f:
        json.dump(data, f, indent=2)


def main():
    # Read color_transform params from theme.json
    hue_shift = 0
    sat_adj = 0.0
    light_adj = 0.0

    try:
        with open(THEME_JSON) as f:
            theme = json.load(f)
        ct = theme.get("color_transform", {})
        hue_shift = float(ct.get("hue_shift", 0))
        sat_adj = float(ct.get("saturation_adjust", 0.0))
        light_adj = float(ct.get("lightness_adjust", 0.0))
    except Exception as e:
        print(f"[color-transform] Kan theme.json niet lezen: {e}", file=sys.stderr)

    # Read matugen JSON from stdin
    raw = sys.stdin.read().strip()
    if not raw:
        sys.exit(0)

    try:
        data = json.loads(raw)
    except Exception as e:
        print(f"[color-transform] Ongeldige JSON op stdin: {e}", file=sys.stderr)
        sys.exit(0)

    # Nothing to do if all transforms are zero — write original as-is
    if hue_shift == 0 and sat_adj == 0.0 and light_adj == 0.0:
        write_colors(data)
        sys.exit(0)

    # Transform all hex color values recursively
    def transform_node(node):
        if isinstance(node, dict):
            return {k: transform_node(v) for k, v in node.items()}
        if isinstance(node, str) and node.startswith("#") and len(node) == 7:
            return transform_color(node, hue_shift, sat_adj, light_adj)
        return node

    try:
        transformed = transform_node(data)
    except Exception as e:
        print(f"[color-transform] Transform mislukt: {e} — originele kleuren behouden", file=sys.stderr)
        write_colors(data)
        sys.exit(0)

    write_colors(transformed)
    print(f"[color-transform] Kleuren aangepast en geschreven naar {OUTPUT_FILE}")


if __name__ == "__main__":
    main()
