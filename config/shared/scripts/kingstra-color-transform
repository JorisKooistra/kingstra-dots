#!/usr/bin/env python3
# =============================================================================
# kingstra-color-transform — Preserve the wallpaper-derived Matugen palette
# =============================================================================
# Gebruik: echo "$MATUGEN_JSON" | kingstra-color-transform
#
# De wallpaper blijft altijd de bron van waarheid voor het palette.
# Thema's mogen styling veranderen, maar niet een los, nieuw kleurensysteem
# introduceren. Daarom schrijft deze stap de originele Matugen JSON ongewijzigd
# weg als cache/artifact voor eventuele tooling.
# =============================================================================

import sys
import json
import os

OUTPUT_FILE = os.path.expanduser(
    os.environ.get("XDG_CONFIG_HOME", os.path.expanduser("~/.config"))
    + "/quickshell/colors-transformed.json"
)


def main():
    raw = sys.stdin.read().strip()
    if not raw:
        sys.exit(0)

    try:
        data = json.loads(raw)
    except Exception as e:
        print(f"[color-transform] Ongeldige JSON op stdin: {e}", file=sys.stderr)
        sys.exit(0)

    os.makedirs(os.path.dirname(OUTPUT_FILE), exist_ok=True)
    with open(OUTPUT_FILE, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2)

    print(f"[color-transform] Palette behouden uit wallpaper en geschreven naar {OUTPUT_FILE}")


if __name__ == "__main__":
    main()
