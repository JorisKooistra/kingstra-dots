{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "left",
  "positionY": "top",
  "control-center-positionX": "left",
  "control-center-positionY": "top",
  "layer": "overlay",
  "layer-shell": true,
  "cssPriority": "application",
  "control-center-width": 420,
  "notification-window-width": 386,
  "control-center-height": 0,
  "control-center-margin-top": 64,
  "control-center-margin-bottom": 8,
  "control-center-margin-right": 0,
  "control-center-margin-left": 56,
  "notification-icon-size": 36,
  "notification-body-image-height": 160,
  "notification-body-image-width": 200,
  "notification-inline-replies": false,
  "notification-visibility": {
    "wallpaper-change-toast": {
      "state": "transient",
      "summary": "^(Wallpaper ingesteld|[Ww]allpaper changed|[Ww]allapper changed|Videowallpaper)$",
      "override-urgency": "low"
    }
  },
  "timeout": 2,
  "timeout-low": 1,
  "timeout-critical": 5,
  "fit-to-screen": false,
  "relative-timestamps": true,
  "hide-on-clear": false,
  "hide-on-action": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "notification-2fa-action": true,
  "keyboard-shortcuts": true,
  "magic-title-toggle": true,
  "control-center-exclusive-zone": false,
  "control-center-widgets": [
    "inhibitors",
    "title",
    "dnd",
    "notifications",
    "mpris"
  ],
  "control-center-widget-radii": 10,
  "widgets": [
    "inhibitors",
    "title",
    "dnd",
    "notifications",
    "mpris"
  ],
  "widget-config": {
    "title": {
      "text": "Notificaties",
      "clear-all-button": true,
      "button-text": "Alles sluiten 󰆴"
    },
    "dnd": {
      "text": "Niet storen"
    },
    "inhibitors": {
      "text": "Inhibitors",
      "button-text": "󰾆 Vrijgeven",
      "clear-all-button": true
    },
    "mpris": {
      "image-size": 96,
      "image-radius": 8
    }
  }
}
